  <!-- About -->
  <string name="about_title">About</string>
  <string name="about_version">Version %1$s</string>
  <string name="about_site_label">Bòcan on the web</string>
  <string name="about_tour_label">Show the welcome tour</string>
  <string name="about_tour_summary">Pairing and first sync, step by step</string>
  <string name="about_privacy_title">Your music stays yours</string>
  <string name="about_privacy_body">Bòcan syncs one way, from your Mac to this phone, over your own Wi-Fi, with both devices verifying each other\'s certificates. There is no cloud, no account, no analytics, and no telemetry. The only things that ever leave this phone are requests to your paired Mac and, only if you turn scrobbling on, the plays you send to a service you choose.</string>
