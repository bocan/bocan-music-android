  <!-- Onboarding -->
  <string name="onboarding_welcome_title">Welcome to Bòcan</string>
  <string name="onboarding_welcome_body">Your Mac\'s music library, in your pocket, on your terms. Pair once with the Mac running Bòcan, and your music, playlists, and podcasts follow you over your own Wi-Fi. No cloud, no account, nothing to configure twice.</string>
