<?xml version="1.0" encoding="utf-8"?>
<!-- Composed from the Mac icon SVG layers 2-spirit, 3-face, and 4-guitar,
     scaled into the adaptive-icon safe zone (the middle 66 percent). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
  android:width="108dp"
  android:height="108dp"
  android:viewportWidth="1024"
  android:viewportHeight="1024">

  <group
    android:scaleX="0.63"
    android:scaleY="0.63"
    android:pivotX="512"
    android:pivotY="512"
    android:translateY="-20">

    <!-- spirit: left ear -->
    <path
      android:fillColor="@color/ic_launcher_spirit"
      android:pathData="M 366 348 C 322 296 250 220 172 168 C 226 178 330 226 452 264 C 420 292 392 320 366 348 Z" />
    <!-- spirit: right ear -->
    <path
      android:fillColor="@color/ic_launcher_spirit"
      android:pathData="M 658 348 C 702 296 774 220 852 168 C 798 178 694 226 572 264 C 604 292 632 320 658 348 Z" />
    <!-- spirit: inner ears -->
    <path
      android:fillColor="@color/ic_launcher_spirit_inner"
      android:pathData="M 380 322 C 348 284 300 234 246 194 C 296 212 366 244 442 270 Z" />
    <path
      android:fillColor="@color/ic_launcher_spirit_inner"
      android:pathData="M 644 322 C 676 284 724 234 778 194 C 728 212 658 244 582 270 Z" />
    <!-- spirit: head, body, and tail wisp -->
    <path
      android:fillColor="@color/ic_launcher_spirit"
      android:pathData="M 512 196 C 388 196 302 290 302 402 C 302 476 322 532 352 572 C 332 650 332 736 356 812 C 380 878 448 908 512 908 C 560 908 606 894 636 866 C 662 902 706 922 758 918 C 718 894 700 852 710 806 C 726 730 716 646 672 574 C 702 532 722 476 722 402 C 722 290 636 196 512 196 Z" />

    <!-- face: closed eyes and smile -->
    <path
      android:strokeColor="@color/ic_launcher_face"
      android:strokeWidth="24"
      android:strokeLineCap="round"
      android:pathData="M 388 408 Q 432 452 476 408" />
    <path
      android:strokeColor="@color/ic_launcher_face"
      android:strokeWidth="24"
      android:strokeLineCap="round"
      android:pathData="M 548 408 Q 592 452 636 408" />
    <path
      android:strokeColor="@color/ic_launcher_face"
      android:strokeWidth="18"
      android:strokeLineCap="round"
      android:pathData="M 478 512 Q 512 538 546 512" />

    <!-- guitar, rotated as in the source art -->
    <group
      android:rotation="-30"
      android:pivotX="420"
      android:pivotY="745">
      <!-- body -->
      <path
        android:fillColor="@color/ic_launcher_guitar_body"
        android:pathData="M 270 745 a 150 125 0 1 0 300 0 a 150 125 0 1 0 -300 0 Z" />
      <!-- neck -->
      <path
        android:fillColor="@color/ic_launcher_guitar_neck"
        android:pathData="M 468 717 H 852 A 28 28 0 0 1 880 745 A 28 28 0 0 1 852 773 H 468 A 28 28 0 0 1 440 745 A 28 28 0 0 1 468 717 Z" />
      <!-- headstock -->
      <path
        android:fillColor="@color/ic_launcher_guitar_body"
        android:pathData="M 884 697 H 940 A 28 28 0 0 1 968 725 V 765 A 28 28 0 0 1 940 793 H 884 A 28 28 0 0 1 856 765 V 725 A 28 28 0 0 1 884 697 Z" />
      <!-- strings -->
      <path
        android:fillColor="@color/ic_launcher_moon"
        android:pathData="M 390 735 H 860 A 10 10 0 0 1 870 745 A 10 10 0 0 1 860 755 H 390 A 10 10 0 0 1 380 745 A 10 10 0 0 1 390 735 Z" />
      <!-- spiral rosette -->
      <path
        android:strokeColor="@color/ic_launcher_moon"
        android:strokeWidth="14"
        android:strokeLineCap="round"
        android:pathData="M 400 780 a 12 12 0 0 1 24 0 a 24 24 0 0 1 -48 0 a 36 36 0 0 1 72 0 a 48 48 0 0 1 -96 0 a 60 60 0 0 1 120 0" />
      <!-- fretting hand -->
      <path
        android:fillColor="@color/ic_launcher_spirit"
        android:strokeColor="@color/ic_launcher_spirit_inner"
        android:strokeWidth="12"
        android:pathData="M 656 745 a 44 44 0 1 0 88 0 a 44 44 0 1 0 -88 0 Z" />
      <!-- strumming hand -->
      <path
        android:fillColor="@color/ic_launcher_spirit"
        android:strokeColor="@color/ic_launcher_spirit_inner"
        android:strokeWidth="12"
        android:pathData="M 434 722 a 46 46 0 1 0 92 0 a 46 46 0 1 0 -92 0 Z" />
    </group>
  </group>
</vector>
